# ─────────────────────────────────────────────────────────────
# loop-engineering-demo 환경변수
# 사용법: cp .env.example .env 후 필요한 값만 채우면 된다.
# 오프라인 리허설은 LLM_PROVIDER=mock 하나면 충분하다 (키 전부 불필요).
# ─────────────────────────────────────────────────────────────

# LLM 프로바이더: gemini | openai | ollama | mock
#  - mock  : API 키/네트워크 없이 전 데모가 결정적으로 완주된다 (리허설용)
#  - gemini: GEMINI_API_KEY 만 넣으면 실제 모델로 전 데모 구동
#  - ollama: 로컬 호스팅 모델 (키 불필요) — 폐쇄망/사내망에서도 동작
# 프로바이더 전환 시 데모 코드는 그대로다 (common/llm.py 의 get_llm()/get_embeddings()
# 인터페이스로 호출부가 모듈화되어 있음)
LLM_PROVIDER=mock

# --- Google Gemini (LLM_PROVIDER=gemini 일 때) ---
# 키 발급: https://aistudio.google.com/apikey  (GOOGLE_API_KEY 이름도 허용)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- OpenAI (LLM_PROVIDER=openai 일 때) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Ollama 로컬 호스팅 (LLM_PROVIDER=ollama 일 때, 키 불필요) ---
# 준비: ollama pull qwen2.5:7b && ollama pull bge-m3
# ⚠ 데모 5(딥 에이전트)까지 쓰려면 도구 호출(tool calling) 지원 모델이어야 한다
#   (qwen2.5, llama3.1 등. 한국어 품질은 exaone3.5:7.8b 도 좋으나 도구 호출 미지원)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=bge-m3          # 한국어 임베딩 권장

# --- Tavily 웹 검색 (선택) ---
# 키가 없으면 web_search 노드는 모의(mock) 검색 결과로 자동 폴백된다.
TAVILY_API_KEY=

# --- Langfuse (데모 3, 5 / selfhost로 로컬 기동) ---
# make up 시 selfhost compose 가 아래 키·계정을 자동 부트스트랩한다 (수정 불필요).
#   대시보드: http://localhost:3000  (demo@example.com / Demo1234!)
# ⚠ 데모 전용 키다 — 운영에서는 반드시 새로 발급할 것.
LANGFUSE_PUBLIC_KEY=pk-lf-loop-demo-0000
LANGFUSE_SECRET_KEY=sk-lf-loop-demo-0000
LANGFUSE_BASE_URL=http://localhost:3000
# (구버전 호환용 별칭 — 비워두면 BASE_URL을 사용)
LANGFUSE_HOST=

# --- OpenTelemetry (데모 4) ---
# 백엔드는 코드가 아니라 이 env로만 결정된다. 데모 4 README 참고.
#   Langfuse: http://localhost:3000/api/public/otel  (+ Basic Auth 헤더 필요)
#   Phoenix : http://localhost:6006/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
# 동시 fan-out 데모: 쉼표 구분 (예: langfuse,phoenix / 디버그용 console 지원)
OTEL_TARGETS=

# --- 데모 2 자동 실행 (verify 전용) ---
# 비워두면 노트북에서 input()으로 직접 입력. approve|edit|reject|all
DEMO2_AUTO=
